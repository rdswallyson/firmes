generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  logo                 String?
  primaryColor         String          @default("#1A3C6E")
  secondaryColor       String          @default("#C8922A")
  domain               String?
  plan                 Plan            @default(FREE)
  isWhiteLabel         Boolean         @default(false)
  maxChurches          Int             @default(1)
  resellerId           String?
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  customDomain         String?
  customName           String?
  stripeCustomerId     String?
  stripePriceId        String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  trialEndsAt          DateTime?
  onboardingCompleted  Boolean         @default(false)
  checkins             Checkin[]
  contas               ContaBancaria[]
  cultos               Culto[]
  cupons               Cupom[]
  escalas              Escala[]
  events               Event[]
  finances             Finance[]
  groups               Group[]
  inscricoes           Inscricao[]
  members              Member[]
  metas                Meta[]
  midias               Midia[]
  pedidos              Pedido[]
  produtos             Produto[]
  reseller             Tenant?         @relation("ResellerChurches", fields: [resellerId], references: [id])
  churches             Tenant[]        @relation("ResellerChurches")
  users                User[]
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String
  role            String    @default("ADMIN")
  tenantId        String
  avatar          String?
  phone           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  acceptedTermsAt DateTime?
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
}

model Member {
  id           String         @id @default(cuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  birthDate    DateTime?
  address      String?
  photo        String?
  memberSince  DateTime       @default(now())
  status       String         @default("ACTIVE")
  role         String?
  groupId      String?
  createdAt    DateTime       @default(now())
  baptismDate  DateTime?
  cep          String?
  city         String?
  complement   String?
  isActive     Boolean        @default(true)
  neighborhood String?
  notes        String?
  number       String?
  state        String?
  updatedAt    DateTime       @default(now()) @updatedAt
  escalas      EscalaMembro[]
  lideraGroups Group[]        @relation("GroupToLeader")
  groups       GroupMember[]
  tenant       Tenant         @relation(fields: [tenantId], references: [id])

  // Campos expandidos
  sexo                    String?
  estadoCivil             String?
  whatsapp                String?
  dataBatismoEspirito     DateTime?
  ministerios             String[]  @default([])
  disponibilidadeDias     String[]  @default([])
  disponibilidadeTurnos   String[]  @default([])
  tags                    String[]  @default([])
  conjugeId               String?
  filhos                  Json?
  indicadoPorId           String?
  comoConheceu            String?
  observacoesPastorais    String?
  portalEmail             String?
  portalPassword          String?
  portalStatus            String?   @default("PENDENTE")
  deletedAt               DateTime?
  phone2                  String?
  cpf                     String?
  rg                      String?
  escolaridade            String?
  pais                    String?
  batizado                String?
  dataConversao           DateTime?
  lgpdAceite              Boolean   @default(false)

  // Relações inversas adicionais
  finances     Finance[]
  lideraGroups2 Group[]       @relation("GroupToLeader2")
  lideraGroups3 Group[]       @relation("GroupToLeader3")
  lideraGroups4 Group[]       @relation("GroupToLeader4")
  cultosPregador  Culto[]     @relation("CultoPregador")
  cultosLouvor    Culto[]     @relation("CultoLiderLouvor")
  eventosOrganizador Event[]  @relation("EventoOrganizador")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, groupId])
  @@index([name])
  @@index([email])
  @@index([birthDate])
  @@index([portalStatus])
}

model Group {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  description String?
  leaderId    String?
  leaderId2   String?
  leaderId3   String?
  leaderId4   String?
  meetingDay  String?
  meetingTime String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  address     String?
  dataAbertura DateTime?
  perfil      String?
  categorias  String[]          @default([])
  grupoOrigemId String?
  leader      Member?           @relation("GroupToLeader", fields: [leaderId], references: [id])
  leader2     Member?           @relation("GroupToLeader2", fields: [leaderId2], references: [id])
  leader3     Member?           @relation("GroupToLeader3", fields: [leaderId3], references: [id])
  leader4     Member?           @relation("GroupToLeader4", fields: [leaderId4], references: [id])
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  frequencias GroupFrequencia[]
  members     GroupMember[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([leaderId])
  @@index([leaderId2])
  @@index([leaderId3])
  @@index([leaderId4])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  memberId String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([groupId, memberId])
}

model GroupFrequencia {
  id         String   @id @default(cuid())
  groupId    String
  date       DateTime
  presentes  Int      @default(0)
  ausentes   Int      @default(0)
  visitantes Int      @default(0)
  observacao String?
  createdAt  DateTime @default(now())
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, date])
}

model Event {
  id                String               @id @default(cuid())
  tenantId          String
  title             String
  description       String?
  date              DateTime
  location          String?
  isPublic          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  banner            String?
  isGratuito        Boolean              @default(true)
  linkExterno       String?
  maxVagas          Int?
  recorrente        Boolean              @default(false)
  slug              String?              @unique
  status            String               @default("ABERTO")
  valor             Float?
  alimentacaoAtiva  Boolean              @default(false)
  alimentacaoModelo String?
  avancado          Boolean              @default(false)
  cidadeExterna     String?
  enderecoRetirada  String?
  instrucaoRetirada String?
  endereco          String?
  googleMapsLink    String?
  organizadorId     String?
  dataFim           DateTime?
  subtitulo         String?
  telefoneObrigatorio Boolean @default(false)
  enderecoObrigatorio Boolean @default(false)
  emailObrigatorio    Boolean @default(false)
  ocultarTelefone     Boolean @default(false)
  ocultarEndereco     Boolean @default(false)
  formaPagamento      String?
  ministerioResponsavel String?
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  organizador       Member?              @relation("EventoOrganizador", fields: [organizadorId], references: [id])
  checkinPontos     EventoCheckinPonto[]
  checklist         EventoChecklist[]
  equipes           EventoEquipe[]
  fases             EventoFase[]
  marcos            EventoMarco[]
  produtos          EventoProduto[]
  recursos          EventoRecurso[]
  refeicoes         EventoRefeicao[]
  inscricoes        Inscricao[]

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([slug])
  @@index([organizadorId])
}

model Inscricao {
  id              String                @id @default(cuid())
  tenantId        String
  eventId         String
  nome            String
  email           String
  telefone        String?
  tipo            String                @default("MEMBRO")
  memberId        String?
  status          String                @default("CONFIRMADO")
  qrCode          String                @unique
  checkinAt       DateTime?
  createdAt       DateTime              @default(now())
  formaPagamento  String?
  lancamentoId    String?
  pagamentoStatus String                @default("PENDENTE")
  scans           EventoCheckinScan[]
  event           Event                 @relation(fields: [eventId], references: [id])
  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  itensPedido     InscricaoPedidoItem[]
  refeicoesUsadas InscricaoRefeicao[]

  @@index([tenantId])
  @@index([eventId])
  @@index([tenantId, status])
  @@index([qrCode])
}

model Finance {
  id            String         @id @default(cuid())
  tenantId      String
  type          String
  category      String
  amount        Float
  description   String?
  date          DateTime       @default(now())
  createdAt     DateTime       @default(now())
  contaId       String?
  isActive      Boolean        @default(true)
  memberId      String?
  memberName    String?
  metaId        String?
  reciboNum     String?
  paymentMethod String?
  status        String         @default("CONFIRMADO")
  conta         ContaBancaria? @relation(fields: [contaId], references: [id])
  meta          Meta?          @relation(fields: [metaId], references: [id])
  member        Member?        @relation(fields: [memberId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([memberId])
}

model ContaBancaria {
  id          String    @id @default(cuid())
  tenantId    String
  nome        String
  banco       String?
  agencia     String?
  numeroConta String?
  saldo       Float     @default(0)
  isAtiva     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  finances    Finance[]

  @@index([tenantId])
}

model Meta {
  id         String    @id @default(cuid())
  tenantId   String
  titulo     String
  descricao  String?
  valorMeta  Float
  valorAtual Float     @default(0)
  dataFim    DateTime?
  isAtiva    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  finances   Finance[]
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  targetId  String
  details   String
  createdAt DateTime @default(now())
}

model EventoRefeicao {
  id      String              @id @default(cuid())
  eventId String
  nome    String
  emoji   String?
  modelo  String
  valor   Float?
  dias    String
  ativo   Boolean             @default(true)
  event   Event               @relation(fields: [eventId], references: [id])
  usadas  InscricaoRefeicao[]
}

model InscricaoRefeicao {
  id          String         @id @default(cuid())
  inscricaoId String
  refeicaoId  String
  dia         String
  usadoEm     DateTime       @default(now())
  inscricao   Inscricao      @relation(fields: [inscricaoId], references: [id])
  refeicao    EventoRefeicao @relation(fields: [refeicaoId], references: [id])

  @@unique([inscricaoId, refeicaoId, dia])
}

model EventoCheckinPonto {
  id      String              @id @default(cuid())
  eventId String
  nome    String
  tipo    String
  qrToken String              @unique
  ativo   Boolean             @default(true)
  event   Event               @relation(fields: [eventId], references: [id])
  scans   EventoCheckinScan[]
}

model EventoCheckinScan {
  id          String             @id @default(cuid())
  pontoId     String
  inscricaoId String
  dataHora    DateTime           @default(now())
  valido      Boolean            @default(true)
  inscricao   Inscricao          @relation(fields: [inscricaoId], references: [id])
  ponto       EventoCheckinPonto @relation(fields: [pontoId], references: [id])
}

model Produto {
  id             String            @id @default(cuid())
  tenantId       String
  nome           String
  descricao      String?
  foto           String?
  preco          Float
  categoria      String
  estoque        Int               @default(0)
  ativo          Boolean           @default(true)
  createdAt      DateTime          @default(now())
  eventoProdutos EventoProduto[]
  pedidoItens    PedidoItem[]
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  variacoes      ProdutoVariacao[]

  @@index([tenantId])
  @@index([tenantId, ativo])
  @@index([tenantId, nome])
}

model ProdutoVariacao {
  id        String  @id @default(cuid())
  produtoId String
  tipo      String
  opcao     String
  estoque   Int     @default(0)
  produto   Produto @relation(fields: [produtoId], references: [id])
}

model Pedido {
  id             String       @id @default(cuid())
  tenantId       String
  memberId       String?
  nomeComprador  String
  telefone       String?
  email          String?
  status         String       @default("PENDENTE")
  formaPagamento String?
  total          Float
  lancamentoId   String?
  eventId        String?
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  itens          PedidoItem[]
}

model PedidoItem {
  id         String    @id @default(cuid())
  pedidoId   String
  produtoId  String
  variacaoId String?
  quantidade Int
  preco      Float
  entregue   Boolean   @default(false)
  entregueEm DateTime?
  pedido     Pedido    @relation(fields: [pedidoId], references: [id])
  produto    Produto   @relation(fields: [produtoId], references: [id])
}

model InscricaoPedidoItem {
  id          String    @id @default(cuid())
  inscricaoId String
  produtoId   String
  variacaoId  String?
  quantidade  Int
  preco       Float
  entregue    Boolean   @default(false)
  entregueEm  DateTime?
  inscricao   Inscricao @relation(fields: [inscricaoId], references: [id])
}

model EventoProduto {
  id        String  @id @default(cuid())
  eventId   String
  produtoId String
  event     Event   @relation(fields: [eventId], references: [id])
  produto   Produto @relation(fields: [produtoId], references: [id])
}

model Cupom {
  id        String    @id @default(cuid())
  tenantId  String
  codigo    String    @unique
  desconto  Float
  tipo      String
  maxUsos   Int?
  usosAtual Int       @default(0)
  validade  DateTime?
  ativo     Boolean   @default(true)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model EventoFase {
  id         String    @id @default(cuid())
  eventId    String
  nome       String
  ordem      Int
  status     String    @default("PENDENTE")
  dataInicio DateTime?
  dataFim    DateTime?
  event      Event     @relation(fields: [eventId], references: [id])
}

model EventoEquipe {
  id            String         @id @default(cuid())
  eventId       String
  nome          String
  funcao        String
  responsavelId String?
  event         Event          @relation(fields: [eventId], references: [id])
  membros       EventoMembro[]
}

model EventoMembro {
  id         String       @id @default(cuid())
  equipeId   String
  pessoaId   String
  funcaoSpec String?
  equipe     EventoEquipe @relation(fields: [equipeId], references: [id])
}

model EventoChecklist {
  id            String    @id @default(cuid())
  eventId       String
  faseId        String?
  descricao     String
  responsavelId String?
  status        String    @default("PENDENTE")
  prazo         DateTime?
  event         Event     @relation(fields: [eventId], references: [id])
}

model EventoMarco {
  id      String   @id @default(cuid())
  eventId String
  titulo  String
  data    DateTime
  status  String   @default("FUTURO")
  obs     String?
  event   Event    @relation(fields: [eventId], references: [id])
}

model EventoRecurso {
  id         String  @id @default(cuid())
  eventId    String
  nome       String
  quantidade String?
  status     String  @default("PENDENTE")
  event      Event   @relation(fields: [eventId], references: [id])
}

model Midia {
  id          String    @id @default(cuid())
  tenantId    String
  titulo      String
  tipo        String
  categoria   String
  url         String
  pregador    String?
  data        DateTime?
  duracao     String?
  reproducoes Int       @default(0)
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, tipo])
}

model CursoCategoria {
  id        String   @id @default(cuid())
  tenantId  String
  nome      String
  cor       String   @default("#1D4ED8")
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([tenantId, nome])
}

model Curso {
  id           String           @id @default(cuid())
  tenantId     String
  titulo       String
  descricao    String?
  banner       String?
  categoria    String           @default("ESTUDO")
  nivel        String           @default("INICIANTE")
  publicado    Boolean          @default(false)
  cargaHoraria Int?
  instrutor    String?
  createdAt    DateTime         @default(now())
  modulos      CursoModulo[]
  progressos   CursoProgresso[]
}

model CursoModulo {
  id      String      @id @default(cuid())
  cursoId String
  titulo  String
  ordem   Int         @default(0)
  aulas   CursoAula[]
  curso   Curso       @relation(fields: [cursoId], references: [id])
}

model CursoAula {
  id         String           @id @default(cuid())
  moduloId   String
  titulo     String
  tipo       String           @default("VIDEO")
  conteudo   String?
  duracao    String?
  ordem      Int              @default(0)
  modulo     CursoModulo      @relation(fields: [moduloId], references: [id])
  progressos CursoProgresso[]
}

model CursoProgresso {
  id        String    @id @default(cuid())
  cursoId   String
  aulaId    String
  memberId  String
  concluido Boolean   @default(false)
  dataHora  DateTime  @default(now())
  aula      CursoAula @relation(fields: [aulaId], references: [id])
  curso     Curso     @relation(fields: [cursoId], references: [id])

  @@unique([cursoId, aulaId, memberId])
}

model Culto {
  id           String    @id @default(cuid())
  tenantId     String
  titulo       String
  data         DateTime
  qrCode       String    @unique
  ativo        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  pregadorId   String?
  liderLouvorId String?
  local        String?
  tipo         String    @default("DOMINICAL")
  descricao    String?
  tema         String?
  serie        String?
  transmissaoUrl String?
  checkins     Checkin[]
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  pregador     Member?   @relation("CultoPregador", fields: [pregadorId], references: [id])
  liderLouvor  Member?   @relation("CultoLiderLouvor", fields: [liderLouvorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, data])
  @@index([tenantId, ativo])
  @@index([pregadorId])
  @@index([liderLouvorId])
}

model Checkin {
  id           String   @id @default(cuid())
  cultoId      String
  tenantId     String
  nome         String
  tipo         String
  memberId     String?
  telefone     String?
  comoConheceu String?
  createdAt    DateTime @default(now())
  culto        Culto    @relation(fields: [cultoId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([cultoId])
  @@index([tenantId, tipo])
}

model Escala {
  id          String         @id @default(cuid())
  tenantId    String
  titulo      String
  data        DateTime
  ministerio  String
  observacoes String?
  status      String         @default("ATIVA")
  createdAt   DateTime       @default(now())
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membros     EscalaMembro[]

  @@index([tenantId])
  @@index([tenantId, data])
  @@index([tenantId, ministerio])
}

model EscalaMembro {
  id        String   @id @default(cuid())
  escalaId  String
  memberId  String
  funcao    String
  status    String   @default("PENDENTE")
  createdAt DateTime @default(now())
  escala    Escala   @relation(fields: [escalaId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([escalaId])
  @@index([memberId])
}

enum Plan {
  FREE
  PRATA
  OURO
  DIAMANTE
  ESMERALDA_STARTER
  ESMERALDA_PRO
  ESMERALDA_PLUS
  ESMERALDA_ULTRA
}
